{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
  "files": {
    "ignoreUnknown": false,
    "ignore": ["node_modules", ".next", "out", "public/fonts", "javafx/build/**", "javafx/src/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": { "useKeyWithClickEvents": "off" },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "include": ["components/ui/command.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useAriaPropsForRole": "off",
            "useFocusableInteractive": "off",
            "useSemanticElements": "off"
          },
          "complexity": { "noForEach": "off" },
          "correctness": { "useExhaustiveDependencies": "off" }
        }
      }
    },
    {
      "include": ["lib/component-examples.tsx"],
      "linter": {
        "rules": {
          "a11y": { "useValidAnchor": "off" }
        }
      }
    }
  ]
}
